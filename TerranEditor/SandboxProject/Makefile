# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  ScriptAssembly_config = debug

else ifeq ($(config),release)
  ScriptAssembly_config = release

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := ScriptAssembly

.PHONY: all clean help $(PROJECTS) 

all: $(PROJECTS)

ScriptAssembly:
ifneq (,$(ScriptAssembly_config))
	@echo "==== Building ScriptAssembly ($(ScriptAssembly_config)) ===="
	@${MAKE} --no-print-directory -C . -f ScriptAssembly.make config=$(ScriptAssembly_config)
endif

clean:
	@${MAKE} --no-print-directory -C . -f ScriptAssembly.make clean

help:
	@echo "Usage: make [config=name] [target]"
	@echo ""
	@echo "CONFIGURATIONS:"
	@echo "  debug"
	@echo "  release"
	@echo ""
	@echo "TARGETS:"
	@echo "   all (default)"
	@echo "   clean"
	@echo "   ScriptAssembly"
	@echo ""
	@echo "For more information, see https://github.com/premake/premake-core/wiki"